# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/altishomes

# CORS — comma-separated origins allowed to call the API
CORS_ORIGIN=http://localhost:5173

# Security — passcode required to unlock the admin dashboard
ADMIN_PASSCODE=admin123

# Seeding — set to "true" to auto-seed MongoDB from data/*.json when collections are empty
SEED_ON_EMPTY=true
